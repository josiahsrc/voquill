---
import Header from "../../components/pathology/Header.astro";
import Footer from "../../components/pathology/Footer.astro";
import BookACall from "../../components/pathology/BookACall.astro";
import { t } from "../../i18n/translations";
import Layout from "../../layouts/Layout.astro";
import { defaultLocale, type Locale } from "../../types/locale";
import { buildSoftwareApplicationStructuredData } from "../../utils/seo";
export { getLocaleStaticPaths as getStaticPaths } from "../../utils/paths";

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const i18n = t(locale);
const structuredData = [buildSoftwareApplicationStructuredData(locale)];
---

<Layout
  title={i18n.siteTitle}
  description={i18n.siteDescription}
  lang={locale}
  structuredData={structuredData}
>
  <Header locale={locale} />

  <main class="pathology-page">
    <section class="hero">
      <div class="hero-copy">
        <span class="eyebrow">Agentic dictation for pathologists</span>
        <h1>Ultra fast voice reporting</h1>
        <p class="subtitle">
          The pathology reporting solution that turns speech into a polished,
          signed-off report in real time.
        </p>
        <div class="hero-actions">
          <BookACall class="btn-primary" />
          <a href="#demo" class="btn-secondary">See a demo</a>
        </div>
      </div>
      <div class="hero-showcase">
        <div class="placeholder placeholder-showcase">Hero product showcase</div>
      </div>
    </section>

    <section class="logos">
      <p class="logos-label">Trusted by pathology teams at</p>
      <div class="logo-row">
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
      </div>
    </section>

    <section class="feature" id="demo">
      <div class="feature-copy">
        <span class="eyebrow">Dictate while you scan</span>
        <h2>Talk through the case. The report writes itself.</h2>
        <p>
          Keep your eyes on the slide. Voquill listens in the background and
          builds the report as you go — and it knows the difference between
          you dictating and you talking to a colleague in the room.
        </p>
      </div>
      <div class="placeholder placeholder-feature">Dictate while you scan</div>
    </section>

    <section class="feature feature-reverse">
      <div class="feature-copy">
        <span class="eyebrow">Agentic field placement</span>
        <h2>Every word in the right field, automatically.</h2>
        <p>
          Gross description, microscopic, interpretation, diagnosis — Voquill
          splits your speech across the fields of your report on its own. No
          more clicking between sections or copy-pasting after the fact.
        </p>
      </div>
      <div class="placeholder placeholder-feature">Field-aware report fill</div>
    </section>

    <section class="feature">
      <div class="feature-copy">
        <span class="eyebrow">Works with what you have</span>
        <h2>Lives on top of any LIS, IMS, or reporting system.</h2>
        <p>
          Voquill runs as a layer over the tools you already use — no rip and
          replace, no migration project, no waiting on IT. Open your existing
          report, start talking, sign out.
        </p>
      </div>
      <div class="placeholder placeholder-feature">LIS / IMS overlay</div>
    </section>

    <section class="bento">
      <div class="section-head">
        <span class="eyebrow">What makes it feel like magic</span>
        <h2>Voice to sign-out, in one pass.</h2>
      </div>
      <div class="bento-grid">
        <div class="bento-tile tile-wide">
          <div class="placeholder placeholder-tile">Edit by voice demo</div>
          <div class="bento-text">
            <h3>Talk to your report</h3>
            <p>
              Done dictating? Just say what you want changed — "move all text
              to the first site," "tighten the diagnosis" — and watch it
              happen, live.
            </p>
          </div>
        </div>
        <div class="bento-tile">
          <div class="placeholder placeholder-tile">Style match</div>
          <div class="bento-text">
            <h3>Learns your style</h3>
            <p>Voquill studies your past reports and writes the way you write.</p>
          </div>
        </div>
        <div class="bento-tile">
          <div class="placeholder placeholder-tile">Snippets</div>
          <div class="bento-text">
            <h3>Snippets that snap in</h3>
            <p>Reusable templates for the phrases and structures you use most.</p>
          </div>
        </div>
        <div class="bento-tile tile-wide">
          <div class="placeholder placeholder-tile">Push-to-talk control</div>
          <div class="bento-text">
            <h3>You're always in control</h3>
            <p>
              Toggle dictation on and off with a single key — like the plus on
              your numpad — so it only listens when you want it to.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="stats-band">
      <div class="stats-inner">
        <div class="stat">
          <div class="stat-number">1 pass</div>
          <div class="stat-label">Voice to signed report</div>
        </div>
        <div class="stat">
          <div class="stat-number">Real time</div>
          <div class="stat-label">Fills as you speak</div>
        </div>
        <div class="stat">
          <div class="stat-number">HIPAA</div>
          <div class="stat-label">Compliant</div>
        </div>
        <div class="stat">
          <div class="stat-number">SOC 2</div>
          <div class="stat-label">In progress</div>
        </div>
      </div>
    </section>

    <section class="steps">
      <div class="section-head">
        <span class="eyebrow">How it works</span>
        <h2>Three moves. Done.</h2>
      </div>
      <div class="steps-row">
        <div class="step">
          <div class="step-num">01</div>
          <div class="placeholder placeholder-step">Dictate</div>
          <h3>Dictate while you scan</h3>
          <p>Speak naturally. Voquill drops every finding into the right field.</p>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="placeholder placeholder-step">Refine</div>
          <h3>Refine by voice</h3>
          <p>Tell the report what to change. It rewrites in front of you.</p>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="placeholder placeholder-step">Sign out</div>
          <h3>Sign out</h3>
          <p>Review the polished draft and finalize. You're done.</p>
        </div>
      </div>
    </section>

    <section class="showcase-wide">
      <div class="placeholder placeholder-wide">Full workflow visualization</div>
    </section>

    <section class="quote">
      <figure>
        <blockquote>"It feels like magic — I just talk through the case and the report is already there."</blockquote>
        <figcaption>
          <div class="placeholder placeholder-avatar">PP</div>
          <div>
            <div class="quote-name">Dr. Name</div>
            <div class="quote-role">Pathologist</div>
          </div>
        </figcaption>
      </figure>
    </section>

  </main>

  <Footer locale={locale} />
</Layout>

<style>
  .pathology-page {
    display: flex;
    flex-direction: column;
    gap: 140px;
    padding-bottom: 40px;
  }

  .pathology-page > section {
    width: min(1120px, 100%);
    margin: 0 auto;
    padding: 0 24px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* HERO */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
    padding-top: 40px !important;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    max-width: 780px;
  }

  .hero h1 {
    font-size: clamp(2.75rem, 5vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 56ch;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .hero-showcase {
    width: 100%;
  }

  .placeholder-showcase {
    aspect-ratio: 16 / 9;
    border-radius: 24px;
  }

  /* LOGOS */
  .logos {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .logos-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .logo-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 32px;
    width: 100%;
    max-width: 880px;
  }

  .placeholder-logo {
    flex: 1 1 140px;
    max-width: 160px;
    aspect-ratio: 4 / 1;
    border-radius: 8px;
    opacity: 0.6;
  }

  /* FEATURE ROWS */
  .feature {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 80px;
    align-items: center;
  }

  .feature-reverse {
    grid-template-columns: 7fr 5fr;
  }

  .feature-reverse .feature-copy {
    order: 2;
  }

  .feature-copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .feature-copy h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .feature-copy p {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 48ch;
  }

  .placeholder-feature {
    aspect-ratio: 4 / 3;
    border-radius: 20px;
  }

  /* BENTO */
  .bento {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    max-width: 640px;
    margin: 0 auto;
  }

  .section-head h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 280px;
    gap: 20px;
  }

  .bento-tile {
    display: flex;
    flex-direction: column;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--level0);
    gap: 16px;
    overflow: hidden;
  }

  .tile-wide {
    grid-column: span 2;
  }

  .bento-tile .placeholder {
    flex: 1;
    min-height: 0;
  }

  .bento-text h3 {
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .bento-text p {
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  .placeholder-tile {
    border-radius: 12px;
  }

  /* STATS BAND */
  .stats-band {
    background: var(--level1);
    border-radius: 28px;
    padding: 56px 40px !important;
    border: 1px solid var(--border);
  }

  .stats-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .stat-number {
    font-size: clamp(2.5rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  /* STEPS */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .steps-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step-num {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }

  .placeholder-step {
    aspect-ratio: 1 / 1;
    border-radius: 16px;
  }

  .step h3 {
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .step p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* SHOWCASE WIDE */
  .placeholder-wide {
    aspect-ratio: 21 / 9;
    border-radius: 24px;
  }

  /* QUOTE */
  .quote figure {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
    text-align: center;
    align-items: center;
  }

  .quote blockquote {
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    line-height: 1.4;
    letter-spacing: -0.015em;
    color: var(--text-strong);
  }

  .quote figcaption {
    display: flex;
    align-items: center;
    gap: 14px;
    text-align: left;
  }

  .placeholder-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    aspect-ratio: 1 / 1;
    font-size: 0.75rem;
  }

  .quote-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .quote-role {
    font-size: 0.85rem;
    color: var(--text-muted);
  }


  /* PLACEHOLDER BASE */
  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--border);
    border-radius: 12px;
    color: var(--text-muted);
    font-size: 0.85rem;
    background: var(--level1);
    text-align: center;
    padding: 12px;
  }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .pathology-page {
      gap: 96px;
    }

    .pathology-page > section {
      padding: 0 16px;
    }

    .stats-band {
      padding: 40px 24px !important;
    }

    .feature,
    .feature-reverse {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .feature-reverse .feature-copy {
      order: 0;
    }

    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 240px;
    }

    .tile-wide {
      grid-column: span 2;
    }

    .stats-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .steps-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .pathology-page > section {
      padding: 0 12px;
    }

    .bento-grid {
      grid-template-columns: 1fr;
    }

    .tile-wide {
      grid-column: span 1;
    }
  }
</style>
