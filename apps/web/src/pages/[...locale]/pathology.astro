---
import Header from "../../components/pathology/Header.astro";
import Footer from "../../components/pathology/Footer.astro";
import BookACall from "../../components/pathology/BookACall.astro";
import { t } from "../../i18n/translations";
import Layout from "../../layouts/Layout.astro";
import { defaultLocale, type Locale } from "../../types/locale";
import { buildSoftwareApplicationStructuredData } from "../../utils/seo";
export { getLocaleStaticPaths as getStaticPaths } from "../../utils/paths";

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const i18n = t(locale);
const structuredData = [buildSoftwareApplicationStructuredData(locale)];
---

<Layout
  title={i18n.siteTitle}
  description={i18n.siteDescription}
  lang={locale}
  structuredData={structuredData}
>
  <Header locale={locale} />

  <main class="pathology-page">
    <section class="hero">
      <div class="hero-copy">
        <span class="eyebrow">For pathology teams</span>
        <h1>Dictation built for pathologists</h1>
        <p class="subtitle">
          Sign out reports faster with voice dictation tuned for pathology
          terminology, synoptic templates, and your workflow.
        </p>
        <div class="hero-actions">
          <BookACall class="btn-primary" />
          <a href="#demo" class="btn-secondary">See a demo</a>
        </div>
      </div>
      <div class="hero-showcase">
        <div class="placeholder placeholder-showcase">Hero product showcase</div>
      </div>
    </section>

    <section class="logos">
      <p class="logos-label">Trusted by pathology teams at</p>
      <div class="logo-row">
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
        <div class="placeholder placeholder-logo">Logo</div>
      </div>
    </section>

    <section class="feature" id="demo">
      <div class="feature-copy">
        <span class="eyebrow">Dictation</span>
        <h2>From dictation to signed-out report</h2>
        <p>
          Speak naturally. Voquill recognizes pathology terminology, drops
          findings into the right fields, and structures the synoptic diagnosis
          for you.
        </p>
      </div>
      <div class="placeholder placeholder-feature">Dictation demo</div>
    </section>

    <section class="feature feature-reverse">
      <div class="feature-copy">
        <span class="eyebrow">Accuracy</span>
        <h2>Accurate on the terms that matter</h2>
        <p>
          Trained for medical vocabulary, grading systems, and staging — so you
          spend less time correcting and more time signing out cases.
        </p>
      </div>
      <div class="placeholder placeholder-feature">Terminology preview</div>
    </section>

    <section class="bento">
      <div class="section-head">
        <span class="eyebrow">What you get</span>
        <h2>Everything you need, nothing you don't</h2>
      </div>
      <div class="bento-grid">
        <div class="bento-tile tile-wide">
          <div class="placeholder placeholder-tile">LIS integration visual</div>
          <div class="bento-text">
            <h3>LIS integration</h3>
            <p>Drops into your existing lab information system.</p>
          </div>
        </div>
        <div class="bento-tile">
          <div class="placeholder placeholder-tile">Macros</div>
          <div class="bento-text">
            <h3>Custom macros</h3>
            <p>Personal shortcuts for phrases you use every day.</p>
          </div>
        </div>
        <div class="bento-tile">
          <div class="placeholder placeholder-tile">Synoptic</div>
          <div class="bento-text">
            <h3>Synoptic templates</h3>
            <p>CAP-aligned structured reporting, ready to go.</p>
          </div>
        </div>
        <div class="bento-tile tile-wide">
          <div class="placeholder placeholder-tile">Privacy diagram</div>
          <div class="bento-text">
            <h3>Private by design</h3>
            <p>On-device processing keeps PHI on your machine.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="stats-band">
      <div class="stats-inner">
        <div class="stat">
          <div class="stat-number">3x</div>
          <div class="stat-label">Faster sign-out</div>
        </div>
        <div class="stat">
          <div class="stat-number">99%</div>
          <div class="stat-label">Term accuracy</div>
        </div>
        <div class="stat">
          <div class="stat-number">40+</div>
          <div class="stat-label">Synoptic templates</div>
        </div>
        <div class="stat">
          <div class="stat-number">HIPAA</div>
          <div class="stat-label">Secure by default</div>
        </div>
      </div>
    </section>

    <section class="steps">
      <div class="section-head">
        <span class="eyebrow">How it works</span>
        <h2>Three steps to a signed report</h2>
      </div>
      <div class="steps-row">
        <div class="step">
          <div class="step-num">01</div>
          <div class="placeholder placeholder-step">Dictate</div>
          <h3>Dictate</h3>
          <p>Speak your findings in natural language.</p>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="placeholder placeholder-step">Structure</div>
          <h3>Structure</h3>
          <p>Fields populate automatically into the template.</p>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="placeholder placeholder-step">Sign out</div>
          <h3>Sign out</h3>
          <p>Review, edit if needed, and finalize.</p>
        </div>
      </div>
    </section>

    <section class="showcase-wide">
      <div class="placeholder placeholder-wide">Full workflow visualization</div>
    </section>

    <section class="quote">
      <figure>
        <blockquote>"Testimonial placeholder — a short, punchy quote from a pathologist goes here."</blockquote>
        <figcaption>
          <div class="placeholder placeholder-avatar">PP</div>
          <div>
            <div class="quote-name">Dr. Name</div>
            <div class="quote-role">Pathologist, Hospital</div>
          </div>
        </figcaption>
      </figure>
    </section>

  </main>

  <Footer locale={locale} />
</Layout>

<style>
  .pathology-page {
    display: flex;
    flex-direction: column;
    gap: 140px;
    padding-bottom: 40px;
  }

  .pathology-page > section {
    width: min(1120px, 100%);
    margin: 0 auto;
    padding: 0 24px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* HERO */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
    padding-top: 40px !important;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    max-width: 780px;
  }

  .hero h1 {
    font-size: clamp(2.75rem, 5vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 56ch;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .hero-showcase {
    width: 100%;
  }

  .placeholder-showcase {
    aspect-ratio: 16 / 9;
    border-radius: 24px;
  }

  /* LOGOS */
  .logos {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .logos-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .logo-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 32px;
    width: 100%;
    max-width: 880px;
  }

  .placeholder-logo {
    flex: 1 1 140px;
    max-width: 160px;
    aspect-ratio: 4 / 1;
    border-radius: 8px;
    opacity: 0.6;
  }

  /* FEATURE ROWS */
  .feature {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 80px;
    align-items: center;
  }

  .feature-reverse {
    grid-template-columns: 7fr 5fr;
  }

  .feature-reverse .feature-copy {
    order: 2;
  }

  .feature-copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .feature-copy h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .feature-copy p {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 48ch;
  }

  .placeholder-feature {
    aspect-ratio: 4 / 3;
    border-radius: 20px;
  }

  /* BENTO */
  .bento {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    max-width: 640px;
    margin: 0 auto;
  }

  .section-head h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 280px;
    gap: 20px;
  }

  .bento-tile {
    display: flex;
    flex-direction: column;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--level0);
    gap: 16px;
    overflow: hidden;
  }

  .tile-wide {
    grid-column: span 2;
  }

  .bento-tile .placeholder {
    flex: 1;
    min-height: 0;
  }

  .bento-text h3 {
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .bento-text p {
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  .placeholder-tile {
    border-radius: 12px;
  }

  /* STATS BAND */
  .stats-band {
    background: var(--level1);
    border-radius: 28px;
    padding: 56px 40px !important;
    border: 1px solid var(--border);
  }

  .stats-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .stat-number {
    font-size: clamp(2.5rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  /* STEPS */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .steps-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step-num {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }

  .placeholder-step {
    aspect-ratio: 1 / 1;
    border-radius: 16px;
  }

  .step h3 {
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .step p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* SHOWCASE WIDE */
  .placeholder-wide {
    aspect-ratio: 21 / 9;
    border-radius: 24px;
  }

  /* QUOTE */
  .quote figure {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
    text-align: center;
    align-items: center;
  }

  .quote blockquote {
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    line-height: 1.4;
    letter-spacing: -0.015em;
    color: var(--text-strong);
  }

  .quote figcaption {
    display: flex;
    align-items: center;
    gap: 14px;
    text-align: left;
  }

  .placeholder-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    aspect-ratio: 1 / 1;
    font-size: 0.75rem;
  }

  .quote-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .quote-role {
    font-size: 0.85rem;
    color: var(--text-muted);
  }


  /* PLACEHOLDER BASE */
  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--border);
    border-radius: 12px;
    color: var(--text-muted);
    font-size: 0.85rem;
    background: var(--level1);
    text-align: center;
    padding: 12px;
  }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .pathology-page {
      gap: 96px;
    }

    .feature,
    .feature-reverse {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .feature-reverse .feature-copy {
      order: 0;
    }

    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 240px;
    }

    .tile-wide {
      grid-column: span 2;
    }

    .stats-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .steps-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .tile-wide {
      grid-column: span 1;
    }

  }
</style>
