---
import Footer from "../../components/pathology/Footer.astro";
import Header from "../../components/pathology/Header.astro";
import Hero from "../../components/pathology/Hero.astro";
import { t } from "../../i18n/translations";
import Layout from "../../layouts/Layout.astro";
import { defaultLocale, type Locale } from "../../types/locale";
import { buildSoftwareApplicationStructuredData } from "../../utils/seo";
export { getLocaleStaticPaths as getStaticPaths } from "../../utils/paths";

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const i18n = t(locale);
const structuredData = [buildSoftwareApplicationStructuredData(locale)];
---

<Layout
  title={i18n.siteTitle}
  description={i18n.siteDescription}
  lang={locale}
  structuredData={structuredData}
>
  <Header locale={locale} />

  <main class="pathology-page">
    <section class="hero-section">
      <Hero />
    </section>

    <section class="hero-video">
      <div class="placeholder placeholder-video">Product video</div>
    </section>

    <section class="feature" id="demo">
      <div class="feature-copy">
        <span class="eyebrow">Describe what you see</span>
        <h2>Talk through the case. The report writes itself.</h2>
        <p>
          Eyes on the slide. Voquill listens in the background and drafts the
          report as you go. Voquill learns your phrasing, your conventions, and
          your preferences, so you sign out instead of edit.
        </p>
      </div>
      <img
        src="/talk-with-slide.png"
        alt="Dictate while you scan"
        class="feature-image dark-invert"
      />
    </section>

    <section class="feature feature-reverse">
      <div class="feature-copy">
        <span class="eyebrow">Agentic field placement</span>
        <h2>Every word in the right field, automatically.</h2>
        <p>
          Specimen, microscopic, interpretation, comments. Voquill routes every
          finding to the right place in your report so you stop clicking around
          to find the right one.
        </p>
      </div>
      <img
        src="/auto-fill-fields.png"
        alt="Field-aware report fill"
        class="feature-image dark-invert"
      />
    </section>

    <section class="feature">
      <div class="feature-copy">
        <span class="eyebrow">Works with what you have</span>
        <h2>Lives on top of any LIS, IMS, or reporting system.</h2>
        <p>
          Voquill sits on top of the tools you already use. Nothing to migrate,
          no IT ticket. Keep the same workflow you have. Just open the case and
          start talking.
        </p>
      </div>
      <img
        src="/works-everywhere.png"
        alt="Works on top of any LIS or IMS"
        class="feature-image dark-invert"
      />
    </section>

    <section class="feature feature-reverse">
      <div class="feature-copy">
        <span class="eyebrow">Your templates, your snippets</span>
        <h2>Bring the templates you already trust.</h2>
        <p>
          GI biopsy, breast excision, prostate core. Whatever you've built over
          the years, Voquill plugs straight in. Your templates and snippets stay
          yours. We just make them faster to fill.
        </p>
      </div>
      <img
        src="/snippets.png"
        alt="Bring your own templates and snippets"
        class="feature-image dark-invert"
      />
    </section>

    <section class="bento">
      <div class="section-head">
        <span class="eyebrow">Why it works</span>
        <h2>Voice to sign-out, in one pass.</h2>
      </div>
      <div class="bento-grid">
        <div class="bento-tile tile-wide">
          <div class="placeholder placeholder-tile">
            Agentic speech recognition
          </div>
          <div class="bento-text">
            <h3>Medical-grade agentic speech</h3>
            <p>
              More than transcription. Voquill understands pathology terminology
              and the commands buried inside your dictation. "Move that to the
              first site." "Put that under interpretation." It acts in real
              time.
            </p>
          </div>
        </div>
        <div class="bento-tile">
          <div class="placeholder placeholder-tile">Style match</div>
          <div class="bento-text">
            <h3>Learns your style</h3>
            <p>Voquill reads your old reports and writes the way you do.</p>
          </div>
        </div>
        <div class="bento-tile">
          <div class="placeholder placeholder-tile">Snippets</div>
          <div class="bento-text">
            <h3>Snippets that snap in</h3>
            <p>Reusable blocks for the phrases you say every day.</p>
          </div>
        </div>
        <div class="bento-tile tile-wide">
          <div class="placeholder placeholder-tile">Push-to-talk control</div>
          <div class="bento-text">
            <h3>Push-to-talk control</h3>
            <p>
              One key turns dictation on and off. It listens only when you want
              it to.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="compliance">
      <div class="section-head">
        <span class="eyebrow">Built for compliance</span>
        <h2>Locked down for privacy.</h2>
        <p class="section-sub">
          Built to meet the security standards your lab requires.
        </p>
      </div>
      <!-- <div class="stats-band"> -->
      <div class="stats-inner">
        <div class="stat">
          <div class="stat-number">HIPAA</div>
          <div class="stat-label">Compliant</div>
        </div>
        <div class="stat">
          <div class="stat-number">SOC 2</div>
          <div class="stat-label">In progress</div>
        </div>
        <div class="stat">
          <div class="stat-number">CAP</div>
          <div class="stat-label">Compliant</div>
        </div>
      </div>
      <!-- </div> -->
    </section>

    <!-- <section class="steps">
      <div class="section-head">
        <span class="eyebrow">How it works</span>
        <h2>Three moves. Done.</h2>
      </div>
      <div class="steps-row">
        <div class="step">
          <div class="step-num">01</div>
          <div class="placeholder placeholder-step">Dictate</div>
          <h3>Dictate while you scan</h3>
          <p>
            Talk through the case. Voquill puts every finding in the right
            field.
          </p>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="placeholder placeholder-step">Refine</div>
          <h3>Refine by voice</h3>
          <p>Tell the report what to change. It rewrites in front of you.</p>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="placeholder placeholder-step">Sign out</div>
          <h3>Sign out</h3>
          <p>Read it. Send it.</p>
        </div>
      </div>
    </section> -->

    <!-- <section class="showcase-wide">
      <div class="placeholder placeholder-wide">
        Full workflow visualization
      </div>
    </section> -->

    <!-- <section class="quote">
      <figure>
        <blockquote>
          "Super "
        </blockquote>
        <figcaption>
          <div class="placeholder placeholder-avatar">MG</div>
          <div>
            <div class="quote-name">Michael Gibson</div>
            <div class="quote-role">Founder</div>
          </div>
        </figcaption>
      </figure>
    </section> -->
  </main>

  <Footer locale={locale} />
</Layout>

<style>
  .pathology-page {
    display: flex;
    flex-direction: column;
    gap: 140px;
    padding-bottom: 40px;
  }

  .pathology-page > section {
    width: min(1120px, 100%);
    margin: 0 auto;
    padding: 0 24px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* HERO */
  .hero-section {
    padding-top: 40px !important;
  }

  .placeholder-video {
    aspect-ratio: 16 / 9;
    border-radius: 24px;
  }

  /* LOGOS */
  .logos {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .logos-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .logo-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 32px;
    width: 100%;
    max-width: 880px;
  }

  .placeholder-logo {
    flex: 1 1 140px;
    max-width: 160px;
    aspect-ratio: 4 / 1;
    border-radius: 8px;
    opacity: 0.6;
  }

  /* FEATURE ROWS */
  .feature {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 80px;
    align-items: center;
  }

  .feature-reverse {
    grid-template-columns: 7fr 5fr;
  }

  .feature-reverse .feature-copy {
    order: 2;
  }

  .feature-copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .feature-copy h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .feature-copy p {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 48ch;
  }

  .placeholder-feature {
    aspect-ratio: 4 / 3;
    border-radius: 20px;
  }

  .feature-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .dark-invert {
    filter: none;
  }

  @media (prefers-color-scheme: dark) {
    .dark-invert {
      filter: invert(1) hue-rotate(180deg) brightness(1.2);
    }
  }

  /* BENTO */
  .bento {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    max-width: 640px;
    margin: 0 auto;
  }

  .section-head h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 280px;
    gap: 20px;
  }

  .bento-tile {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--level0);
    overflow: hidden;
  }

  .tile-wide {
    grid-column: span 2;
  }

  .bento-tile .placeholder {
    flex: 1;
    min-height: 0;
    border-radius: 0;
    border: none;
    border-bottom: 1px dashed var(--border);
  }

  .bento-text {
    padding: 20px 24px 24px;
  }

  .bento-text h3 {
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .bento-text p {
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  .placeholder-tile {
    border-radius: 0;
  }

  /* STATS BAND */
  .stats-band {
    background: var(--level1);
    border-radius: 28px;
    padding: 56px 40px !important;
    border: 1px solid var(--border);
  }

  .compliance {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .section-sub {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 56ch;
  }

  .stats-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .stat-number {
    font-size: clamp(2.5rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  /* STEPS */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .steps-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step-num {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }

  .placeholder-step {
    aspect-ratio: 1 / 1;
    border-radius: 16px;
  }

  .step h3 {
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .step p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* SHOWCASE WIDE */
  .placeholder-wide {
    aspect-ratio: 21 / 9;
    border-radius: 24px;
  }

  /* QUOTE */
  .quote figure {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
    text-align: center;
    align-items: center;
  }

  .quote blockquote {
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    line-height: 1.4;
    letter-spacing: -0.015em;
    color: var(--text-strong);
  }

  .quote figcaption {
    display: flex;
    align-items: center;
    gap: 14px;
    text-align: left;
  }

  .placeholder-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    aspect-ratio: 1 / 1;
    font-size: 0.75rem;
  }

  .quote-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .quote-role {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  /* PLACEHOLDER BASE */
  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--border);
    border-radius: 12px;
    color: var(--text-muted);
    font-size: 0.85rem;
    background: var(--level1);
    text-align: center;
    padding: 12px;
  }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .pathology-page {
      gap: 96px;
    }

    .pathology-page > section {
      padding: 0 16px;
    }

    .stats-band {
      padding: 40px 24px !important;
    }

    .feature,
    .feature-reverse {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .feature-reverse .feature-copy {
      order: 0;
    }

    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 240px;
    }

    .tile-wide {
      grid-column: span 2;
    }

    .stats-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .steps-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .pathology-page > section {
      padding: 0 12px;
    }

    .bento-grid {
      grid-template-columns: 1fr;
    }

    .tile-wide {
      grid-column: span 1;
    }
  }
</style>
