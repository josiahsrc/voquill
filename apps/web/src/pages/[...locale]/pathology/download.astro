---
import Footer from "../../../components/pathology/Footer.astro";
import Header from "../../../components/pathology/Header.astro";
import Layout from "../../../layouts/Layout.astro";
import { defaultLocale, type Locale } from "../../../types/locale";
import { buildSoftwareApplicationStructuredData } from "../../../utils/seo";
export { getLocaleStaticPaths as getStaticPaths } from "../../../utils/paths";

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const structuredData = [buildSoftwareApplicationStructuredData(locale)];
---

<Layout
  title="Download Voquill for Pathology"
  description="Download Voquill for pathology — AI voice reporting for macOS, Windows, and Linux."
  lang={locale}
  structuredData={structuredData}
>
  <Header locale={locale} />

  <main class="pathology-download">
    <section class="download-hero">
      <div class="hero-copy">
        <span class="eyebrow">for pathologists</span>
        <h1>Download Voquill</h1>
        <p class="subtitle">
          AI voice reporting for your workstation. macOS, Windows, and Linux.
        </p>
        <div class="download-primary">
          <a
            id="primary-download"
            href="#platforms"
            class="btn-primary download-primary-button"
            data-track="PathologyDownload"
          >
            <span class="download-button-icon" aria-hidden="true"></span>
            <span class="download-button-label">Download for your device</span>
          </a>
          <span class="download-recommendation"></span>
        </div>
      </div>
      <div class="hero-image-wrap">
        <img
          src="/talk-with-slide.png"
          alt="A pathologist dictating findings while looking through a microscope"
          class="hero-image dark-invert"
          width="320"
          height="320"
        />
      </div>
    </section>

    <section
      id="platforms"
      class="platforms"
      aria-label="All download options"
    >
      <h2 class="platforms-heading">All platforms</h2>
      <div class="platforms-grid">
        <article class="platform" data-platform="mac">
          <header class="platform-header">
            <span
              class="platform-icon"
              style="mask-image: url(/apple.svg); -webkit-mask-image: url(/apple.svg);"
              aria-hidden="true"></span>
            <h3 class="platform-name">macOS</h3>
          </header>
          <span class="platform-empty download-empty">Loading…</span>
        </article>

        <article class="platform" data-platform="windows">
          <header class="platform-header">
            <span
              class="platform-icon"
              style="mask-image: url(/windows.svg); -webkit-mask-image: url(/windows.svg);"
              aria-hidden="true"></span>
            <h3 class="platform-name">Windows</h3>
          </header>
          <span class="platform-empty download-empty">Loading…</span>
        </article>

        <article class="platform" data-platform="linux">
          <header class="platform-header">
            <span
              class="platform-icon"
              style="mask-image: url(/ubuntu.svg); -webkit-mask-image: url(/ubuntu.svg);"
              aria-hidden="true"></span>
            <h3 class="platform-name">Linux</h3>
          </header>
          <span class="platform-empty download-empty">Loading…</span>
        </article>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</Layout>

<script>
  const RELEASES_API_URL =
    "https://api.github.com/repos/voquill/voquill/releases";
  const ENTERPRISE_TAG_PATTERN = /^desktop-enterprise-v\d/;

  const MANIFEST_KEY_DETAILS: Record<
    string,
    { platform: string; label: string; description?: string }
  > = {
    "darwin-universal": {
      platform: "mac",
      label: "macOS (Universal)",
      description: ".dmg installer",
    },
    "darwin-universal-pkg": {
      platform: "mac",
      label: "macOS (Universal)",
      description: ".pkg installer",
    },
    "windows-x86_64": {
      platform: "windows",
      label: "Windows (x64)",
      description: ".msi installer",
    },
    "windows-x86_64-nsis": {
      platform: "windows",
      label: "Windows (x64)",
      description: "Setup installer",
    },
    "linux-x86_64": {
      platform: "linux",
      label: "Linux (x86_64)",
      description: "AppImage",
    },
    "linux-x86_64-deb": {
      platform: "linux",
      label: "Linux (x86_64)",
      description: ".deb package",
    },
    "linux-x86_64-rpm": {
      platform: "linux",
      label: "Linux (x86_64)",
      description: ".rpm package",
    },
  };

  const PLATFORM_ORDER = ["mac", "windows", "linux"];
  const PLATFORM_NAMES: Record<string, string> = {
    mac: "macOS",
    windows: "Windows",
    linux: "Linux",
  };
  const PLATFORM_ICONS: Record<string, string> = {
    mac: "/apple.svg",
    windows: "/windows.svg",
    linux: "/ubuntu.svg",
  };

  const ASSET_KEY_MAPPINGS = [
    {
      match: (n: string) =>
        /^voquill-desktop-enterprise[-_].*\.appimage$/i.test(n),
      keys: ["linux-x86_64"],
    },
    {
      match: (n: string) =>
        /^voquill-desktop-enterprise[-_].*\.deb$/i.test(n),
      keys: ["linux-x86_64-deb"],
    },
    {
      match: (n: string) =>
        /^voquill-desktop-enterprise[-_].*\.rpm$/i.test(n),
      keys: ["linux-x86_64-rpm"],
    },
    {
      match: (n: string) => /enterprise.*\.dmg$/i.test(n),
      keys: ["darwin-universal"],
    },
    {
      match: (n: string) => /enterprise.*\.pkg$/i.test(n),
      keys: ["darwin-universal-pkg"],
    },
    {
      match: (n: string) => /enterprise.*\.msi$/i.test(n),
      keys: ["windows-x86_64"],
    },
    {
      match: (n: string) => /enterprise.*setup.*\.exe$/i.test(n),
      keys: ["windows-x86_64-nsis"],
    },
  ];

  type PlatformDownload = {
    platform: string;
    key: string;
    label: string;
    description?: string;
    url: string;
  };

  function detectPlatform() {
    var nav = window.navigator;
    var hint = (nav as any).userAgentData
      ? (nav as any).userAgentData.platform || ""
      : "";
    var ua = [nav.userAgent || "", hint, nav.platform || ""]
      .join(" ")
      .toLowerCase();
    if (ua.includes("win")) return "windows";
    if (ua.includes("mac") || ua.includes("darwin")) return "mac";
    if (ua.includes("linux") && !ua.includes("android")) return "linux";
    return "mac";
  }

  function resolveManifestKeys(asset: { name: string }) {
    var name = asset.name.toLowerCase();
    if (name.endsWith(".sig")) return undefined;
    if (name.endsWith(".json")) return undefined;
    if (/\.app\.tar\.gz$/i.test(name)) return undefined;
    if (name.includes("gpu")) return undefined;
    for (var i = 0; i < ASSET_KEY_MAPPINGS.length; i++) {
      if (ASSET_KEY_MAPPINGS[i].match(name)) return ASSET_KEY_MAPPINGS[i].keys;
    }
    return undefined;
  }

  function normalizeVersion(tag?: string) {
    if (!tag) return "latest";
    var trimmed = tag.trim();
    if (!trimmed) return "latest";
    return trimmed.replace(/^desktop-enterprise-v/i, "");
  }

  function transformGithubRelease(release: any) {
    var assets = release.assets || [];
    var platforms: Record<string, { url: string }> = {};
    for (var i = 0; i < assets.length; i++) {
      var keys = resolveManifestKeys(assets[i]);
      if (!keys) continue;
      for (var j = 0; j < keys.length; j++) {
        if (!platforms[keys[j]]) {
          platforms[keys[j]] = { url: assets[i].browser_download_url };
        }
      }
    }
    if (Object.keys(platforms).length === 0) return undefined;
    return {
      version: normalizeVersion(release.tag_name ?? release.name),
      platforms,
    };
  }

  async function fetchReleaseManifest() {
    try {
      var response = await fetch(RELEASES_API_URL, {
        headers: { Accept: "application/vnd.github+json" },
      });
      if (!response.ok) return undefined;
      var allReleases = await response.json();
      var selected = allReleases.filter(function (r: any) {
        return r.tag_name && ENTERPRISE_TAG_PATTERN.test(r.tag_name);
      });
      var latest = selected[0];
      if (!latest) return undefined;
      var manifest = transformGithubRelease(latest);
      if (!manifest) return undefined;
      var fallback = selected[1];
      if (fallback) {
        var fallbackManifest = transformGithubRelease(fallback);
        if (fallbackManifest) {
          for (var key in fallbackManifest.platforms) {
            if (!manifest.platforms[key])
              manifest.platforms[key] = fallbackManifest.platforms[key];
          }
        }
      }
      return manifest;
    } catch (_e) {
      return undefined;
    }
  }

  function extractDownloads(manifest: {
    platforms: Record<string, { url: string }>;
  }): PlatformDownload[] {
    return Object.entries(manifest.platforms)
      .flatMap(function ([key, details]) {
        if (!details?.url) return [];
        var meta = MANIFEST_KEY_DETAILS[key];
        if (!meta) return [];
        return [
          {
            platform: meta.platform,
            key: key,
            label: meta.label,
            description: meta.description,
            url: details.url,
          },
        ];
      })
      .sort(function (a, b) {
        var po =
          PLATFORM_ORDER.indexOf(a.platform) -
          PLATFORM_ORDER.indexOf(b.platform);
        if (po !== 0) return po;
        return a.label.localeCompare(b.label);
      });
  }

  function renderCard(card: HTMLElement, downloads: PlatformDownload[]) {
    var empty = card.querySelector(".download-empty");

    if (downloads.length > 0) {
      if (empty) empty.remove();

      var list = document.createElement("ul");
      list.className = "download-link-list";

      downloads.forEach(function (dl) {
        var li = document.createElement("li");
        li.className = "download-link-item";
        var a = document.createElement("a");
        a.href = dl.url;
        a.className = "download-link";
        a.target = "_blank";
        a.rel = "noopener noreferrer";

        var labelSpan = document.createElement("span");
        labelSpan.textContent = dl.label;
        a.appendChild(labelSpan);

        if (dl.description) {
          var descSpan = document.createElement("span");
          descSpan.className = "download-link-description";
          descSpan.textContent = dl.description;
          a.appendChild(descSpan);
        }

        li.appendChild(a);
        list.appendChild(li);
      });

      card.appendChild(list);
    } else {
      if (empty) empty.textContent = "Currently unavailable";
    }
  }

  function pickPrimaryDownload(
    grouped: Record<string, PlatformDownload[]>,
    platform: string,
  ): PlatformDownload | undefined {
    var list = grouped[platform] || [];
    if (list.length === 0) return undefined;
    var preferredKeys: string[] =
      platform === "mac"
        ? ["darwin-universal", "darwin-universal-pkg"]
        : platform === "windows"
          ? ["windows-x86_64-nsis", "windows-x86_64"]
          : ["linux-x86_64", "linux-x86_64-deb", "linux-x86_64-rpm"];
    for (var i = 0; i < preferredKeys.length; i++) {
      var match = list.find(function (d) {
        return d.key === preferredKeys[i];
      });
      if (match) return match;
    }
    return list[0];
  }

  document.addEventListener("DOMContentLoaded", async function () {
    var recEl = document.querySelector(
      ".download-recommendation",
    ) as HTMLElement;
    var primaryBtn = document.getElementById(
      "primary-download",
    ) as HTMLAnchorElement | null;
    var iconSpan = primaryBtn?.querySelector(
      ".download-button-icon",
    ) as HTMLElement | null;
    var labelSpan = primaryBtn?.querySelector(
      ".download-button-label",
    ) as HTMLElement | null;

    var cards = document.querySelectorAll(
      ".platform",
    ) as NodeListOf<HTMLElement>;

    var platform = detectPlatform();
    var displayName = PLATFORM_NAMES[platform] || "macOS";

    if (iconSpan) {
      var iconUrl = PLATFORM_ICONS[platform] || PLATFORM_ICONS.mac;
      iconSpan.style.setProperty("mask-image", "url(" + iconUrl + ")");
      iconSpan.style.setProperty("-webkit-mask-image", "url(" + iconUrl + ")");
    }
    if (labelSpan) {
      labelSpan.textContent = "Download for " + displayName;
    }

    var manifest = await fetchReleaseManifest();

    if (!manifest) {
      if (recEl) recEl.textContent = displayName + " download";
      cards.forEach(function (card) {
        var empty = card.querySelector(".download-empty");
        if (empty) empty.textContent = "Currently unavailable";
      });
      return;
    }

    if (recEl) {
      recEl.textContent =
        displayName + " " + manifest.version + " (recommended)";
    }

    var downloads = extractDownloads(manifest);
    var grouped: Record<string, PlatformDownload[]> = {
      mac: [],
      windows: [],
      linux: [],
    };
    downloads.forEach(function (dl) {
      if (grouped[dl.platform]) grouped[dl.platform].push(dl);
    });

    var primary = pickPrimaryDownload(grouped, platform);
    if (primary && primaryBtn) {
      primaryBtn.href = primary.url;
      primaryBtn.target = "_blank";
      primaryBtn.rel = "noopener noreferrer";
    }

    cards.forEach(function (card) {
      var p = card.dataset.platform || "";
      renderCard(card, grouped[p] || []);
    });
  });
</script>

<style>
  .pathology-download {
    width: min(1040px, 100%);
    margin: 0 auto;
    padding: 24px 24px 80px;
    display: flex;
    flex-direction: column;
    gap: 96px;
  }

  /* HERO */
  .download-hero {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 64px;
    align-items: center;
    padding-top: 24px;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    max-width: 56ch;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .download-hero h1 {
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    letter-spacing: -0.04em;
    line-height: 1.02;
  }

  .subtitle {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 48ch;
  }

  .download-primary {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: flex-start;
    margin-top: 12px;
  }

  :global(.download-primary-button) {
    padding: 14px 28px;
    font-size: 1rem;
    gap: 10px;
  }

  :global(.download-button-icon) {
    display: inline-block;
    width: 18px;
    height: 18px;
    background-color: currentColor;
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    flex-shrink: 0;
  }

  .download-recommendation {
    font-size: 0.9rem;
    color: var(--text-muted);
    min-height: 1.25em;
  }

  .hero-image-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image {
    width: 100%;
    max-width: 360px;
    height: auto;
    display: block;
  }

  .dark-invert {
    filter: none;
  }

  @media (prefers-color-scheme: dark) {
    .dark-invert {
      filter: invert(1) hue-rotate(180deg) brightness(1.2);
    }
  }

  /* PLATFORMS */
  .platforms {
    display: flex;
    flex-direction: column;
    gap: 32px;
    border-top: 1px solid var(--border);
    padding-top: 56px;
  }

  .platforms-heading {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 56px;
  }

  .platform {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .platform-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .platform-icon {
    display: inline-block;
    width: 22px;
    height: 22px;
    background-color: var(--text-strong);
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    flex-shrink: 0;
  }

  .platform-name {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  :global(.download-link-list) {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-left: 0;
    margin: 0;
  }

  :global(.download-link-item) {
    display: flex;
    flex-direction: column;
  }

  :global(.download-link) {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-strong);
    text-decoration: none;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  :global(.download-link:hover) {
    color: var(--primary-button-bg);
  }

  :global(.download-link > span:first-child) {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  :global(.download-link-description) {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 400;
    text-decoration: none;
  }

  :global(.download-empty) {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 960px) {
    .download-hero {
      grid-template-columns: 1fr;
      gap: 24px;
      text-align: left;
    }

    .hero-image-wrap {
      order: -1;
      justify-content: flex-start;
    }

    .hero-image {
      max-width: 220px;
    }

    .platforms-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 720px) {
    .pathology-download {
      padding: 16px 16px 56px;
      gap: 64px;
    }

    .platforms {
      padding-top: 40px;
    }
  }
</style>
