---
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import LegalLayout from '../../layouts/LegalLayout.astro';
import type { Locale } from '../../types/locale';

export function getStaticPaths() {
	return [{ params: { locale: 'en' } }, { params: { locale: 'es' } }];
}

const locale = Astro.params.locale as Locale;

const mdPath = path.resolve('content/delete-account.md');
const mdContent = fs.readFileSync(mdPath, 'utf-8');

marked.setOptions({ gfm: true, breaks: true });
const html = await marked.parse(mdContent);
---

<LegalLayout title="Delete Account | Voquill" description="Learn how to delete your Voquill account." locale={locale}>
	<Fragment set:html={html} />
</LegalLayout>
