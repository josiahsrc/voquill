---
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { type Locale, t } from '../../i18n/translations';

export function getStaticPaths() {
	return [{ params: { locale: 'en' } }, { params: { locale: 'es' } }];
}

const locale = Astro.params.locale as Locale;
const i18n = t(locale);

const mdPath = path.resolve('content/privacy.md');
const mdContent = fs.readFileSync(mdPath, 'utf-8');

marked.setOptions({ gfm: true, breaks: true });
const html = await marked.parse(mdContent);
---

<Layout title={`Privacy Policy | Voquill`} description="Voquill privacy policy" lang={locale}>
	<Header locale={locale} />
	<main class="legal-main">
		<article class="legal-content" set:html={html} />
	</main>
	<SiteFooter locale={locale} />
</Layout>

<style>
	.legal-main {
		width: min(840px, 100%);
		margin: 0 auto;
		padding: 0 24px 120px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.legal-content {
		line-height: 1.75;
	}

	.legal-content :global(h1) {
		font-size: clamp(2.2rem, 4vw, 2.8rem);
		letter-spacing: -0.02em;
	}

	.legal-content :global(p) {
		margin: 16px 0;
		opacity: 0.8;
	}

	.legal-content :global(h2) {
		margin-top: 36px;
		margin-bottom: 12px;
		font-size: clamp(1.45rem, 2.6vw, 1.75rem);
		letter-spacing: -0.01em;
	}

	.legal-content :global(h3) {
		margin-top: 28px;
		margin-bottom: 8px;
		font-size: 1.2rem;
		letter-spacing: -0.01em;
	}

	.legal-content :global(ul),
	.legal-content :global(ol) {
		margin: 18px 0 18px 24px;
		padding-left: 20px;
		display: grid;
		gap: 8px;
		opacity: 0.8;
	}

	.legal-content :global(a) {
		color: inherit;
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 4px;
	}

	.legal-content :global(em) {
		opacity: 0.95;
	}

	.legal-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 18px 0;
		font-size: 0.95rem;
	}

	.legal-content :global(th),
	.legal-content :global(td) {
		padding: 10px 16px;
		text-align: left;
		border: 1px solid var(--border);
	}

	.legal-content :global(th) {
		background: var(--level1);
		font-weight: 600;
	}

	@media (max-width: 600px) {
		.legal-main {
			padding: 0 16px 96px;
		}
	}
</style>
