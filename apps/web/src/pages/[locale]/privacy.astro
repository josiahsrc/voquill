---
import LegalLayout from '../../layouts/LegalLayout.astro';
import { renderLocalizedMarkdownFile } from '../../lib/markdown';
import { locales, type Locale } from '../../types/locale';

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const html = await renderLocalizedMarkdownFile('content/privacy.md', locale);
---

<LegalLayout title="Privacy Policy | Voquill" description="Voquill privacy policy" locale={locale}>
	<Fragment set:html={html} />
</LegalLayout>
