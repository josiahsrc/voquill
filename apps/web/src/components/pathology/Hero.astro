---
import BookACall from "./BookACall.astro";
---

<div class="pathology-hero">
  <div class="hero-copy">
    <span class="eyebrow">Agentic dictation for pathologists</span>
    <h1>Ultra fast<br />voice reporting</h1>
    <p class="subtitle">
      The pathology reporting solution that turns your voice into a polished,
      signed-off report in real time.
    </p>
    <div class="hero-actions">
      <BookACall class="btn-primary" />
      <a href="#demo" class="btn-secondary">See a demo</a>
    </div>
  </div>
  <div class="hero-graphic" aria-hidden="true"></div>
</div>

<style>
  .pathology-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 20px;
    max-width: 780px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .pathology-hero h1 {
    font-size: clamp(2.75rem, 5vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 56ch;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .hero-graphic {
    position: relative;
    width: 100%;
    min-height: 480px;
    overflow: visible;
  }

  :global(.hero-svg) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200vw;
    height: 200vh;
    pointer-events: none;
  }

  :global(.hero-wave-path) {
    stroke: rgba(0, 0, 0, 1);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  :global(.hero-path-text) {
    font-size: 14px;
    font-weight: 500;
    font-family: system-ui, -apple-system, sans-serif;
    fill: rgba(0, 0, 0, 0.7);
  }

  :global(.hero-icon-glow) {
    fill: rgba(0, 0, 0, 0.04);
    filter: blur(8px);
  }

  :global(.hero-icon-circle) {
    fill: #111111;
  }

  :global(.hero-icon-logo) {
    filter: invert(1);
  }

  :global(.hero-spark) {
    fill: rgba(0, 0, 0, 0.6);
  }

  @media (prefers-color-scheme: dark) {
    :global(.hero-wave-path) {
      stroke: rgba(255, 255, 255, 1);
    }

    :global(.hero-path-text) {
      fill: rgba(255, 255, 255, 0.7);
    }

    :global(.hero-icon-glow) {
      fill: rgba(255, 255, 255, 0.08);
    }

    :global(.hero-icon-circle) {
      fill: #ffffff;
    }

    :global(.hero-icon-logo) {
      filter: none;
    }

    :global(.hero-spark) {
      fill: rgba(255, 255, 255, 0.6);
    }
  }

  @media (max-width: 960px) {
    .pathology-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .hero-graphic {
      display: none;
    }
  }
</style>

<script>
  (function () {
    function bezierPoint(
      curve: {
        sx: number;
        sy: number;
        c1x: number;
        c1y: number;
        c2x: number;
        c2y: number;
        ex: number;
        ey: number;
      },
      t: number,
    ) {
      var mt = 1 - t,
        mt2 = mt * mt,
        mt3 = mt2 * mt,
        t2 = t * t,
        t3 = t2 * t;

      var x =
        mt3 * curve.sx +
        3 * mt2 * t * curve.c1x +
        3 * mt * t2 * curve.c2x +
        t3 * curve.ex;
      var y =
        mt3 * curve.sy +
        3 * mt2 * t * curve.c1y +
        3 * mt * t2 * curve.c2y +
        t3 * curve.ey;

      var dx =
        3 * mt2 * (curve.c1x - curve.sx) +
        6 * mt * t * (curve.c2x - curve.c1x) +
        3 * t2 * (curve.ex - curve.c2x);
      var dy =
        3 * mt2 * (curve.c1y - curve.sy) +
        6 * mt * t * (curve.c2y - curve.c1y) +
        3 * t2 * (curve.ey - curve.c2y);

      return { x: x, y: y, angle: Math.atan2(dy, dx) };
    }

    function generateWavePath(
      curve: {
        sx: number;
        sy: number;
        c1x: number;
        c1y: number;
        c2x: number;
        c2y: number;
        ex: number;
        ey: number;
      },
      frequency: number,
      amplitude: number,
      timeOffset: number,
    ) {
      var segments = 100;
      var parts = [];
      for (var i = 0; i <= segments; i++) {
        var t = i / segments;
        var p = bezierPoint(curve, t);
        var perpX = -Math.sin(p.angle);
        var perpY = Math.cos(p.angle);
        var phase = t * frequency * Math.PI * 2 - timeOffset;
        var sineValue = Math.sin(phase) * amplitude;
        var fadeIn = Math.min(1, t * 5);
        var fadeOut = Math.min(1, (1 - t) * 5);
        var fade = fadeIn * fadeOut;
        var px = p.x + perpX * sineValue * fade;
        var py = p.y + perpY * sineValue * fade;
        parts.push(
          (i === 0 ? "M " : "L ") + px.toFixed(2) + " " + py.toFixed(2),
        );
      }
      return parts.join(" ");
    }

    function seededRandom(seed: number) {
      var x = Math.sin(seed * 12.9898 + seed * 78.233) * 43758.5453;
      return x - Math.floor(x);
    }

    var WAVE_CONFIGS = [
      { frequency: 16 / 3, amplitude: 14, duration: 1.5, opacity: 0.5 },
      { frequency: 24 / 3, amplitude: 10, duration: 1.2, opacity: 0.35 },
      { frequency: 36 / 3, amplitude: 6, duration: 1, opacity: 0.25 },
    ];

    var WAVE_FRAMES = 20;

    var BASE_TEXT =
      "Sections show invasive ductal carcinoma, Nottingham grade 2, measuring 1.8 centimeters in greatest dimension. Surgical margins are negative. No lymphovascular invasion identified. ";
    var REPEATED_TEXT = "";
    for (var r = 0; r < 10; r++) REPEATED_TEXT += BASE_TEXT;

    var SPARKS: Array<{
      tx: number;
      ty: number;
      delay: number;
      dur: number;
    }> = [];
    for (var i = 0; i < 6; i++) {
      var angle = seededRandom(i * 3.3) * Math.PI * 2;
      var distance = 80 + seededRandom(i * 4.4) * 60;
      SPARKS.push({
        tx: Math.cos(angle) * distance,
        ty: Math.sin(angle) * distance,
        delay: seededRandom(i * 1.1) * 2,
        dur: 0.6 + seededRandom(i * 2.2) * 0.5,
      });
    }

    function buildGraphic() {
      var NS = "http://www.w3.org/2000/svg";
      var vw = 1000,
        vh = 750;
      var cx = vw,
        cy = vh;
      var iconX = cx,
        iconY = cy;

      var inputCurve = {
        sx: cx - vw * 0.1,
        sy: -50,
        c1x: cx + vw * 0.2,
        c1y: cy - vh * 0.8,
        c2x: cx - vw * 0.5,
        c2y: cy - vh * 0.1,
        ex: iconX - 28,
        ey: iconY - 5,
      };

      var outputCurve = {
        sx: iconX + 28,
        sy: iconY + 8,
        c1x: cx + vw * 0.4,
        c1y: cy + vh * 0.1,
        c2x: cx,
        c2y: cy + vh * 0.4,
        ex: cx + vw * 0.7,
        ey: cy + vh * 0.5,
      };

      var outputCurvePath =
        "M " +
        outputCurve.sx +
        " " +
        outputCurve.sy +
        " C " +
        outputCurve.c1x +
        " " +
        outputCurve.c1y +
        ", " +
        outputCurve.c2x +
        " " +
        outputCurve.c2y +
        ", " +
        outputCurve.ex +
        " " +
        outputCurve.ey;

      var wavesData = WAVE_CONFIGS.map(function (cfg) {
        var frames = [];
        for (var f = 0; f < WAVE_FRAMES; f++) {
          var timeOffset = (f / WAVE_FRAMES) * Math.PI * 2;
          frames.push(
            generateWavePath(inputCurve, cfg.frequency, cfg.amplitude, timeOffset),
          );
        }
        frames.push(frames[0]);
        return {
          frames: frames.join(";"),
          opacity: cfg.opacity,
          duration: cfg.duration,
        };
      });

      var svg = document.createElementNS(NS, "svg");
      svg.setAttribute("class", "hero-svg");
      svg.setAttribute("viewBox", "0 0 " + vw * 2 + " " + vh * 2);
      svg.setAttribute("preserveAspectRatio", "xMidYMid slice");

      var defs = document.createElementNS(NS, "defs");
      var defPath = document.createElementNS(NS, "path");
      defPath.setAttribute("id", "outputTextPath");
      defPath.setAttribute("d", outputCurvePath);
      defPath.setAttribute("fill", "none");
      defs.appendChild(defPath);
      svg.appendChild(defs);

      wavesData.forEach(function (w) {
        var path = document.createElementNS(NS, "path");
        path.setAttribute("fill", "none");
        path.setAttribute("class", "hero-wave-path");
        path.setAttribute("style", "opacity:" + w.opacity);
        var anim = document.createElementNS(NS, "animate");
        anim.setAttribute("attributeName", "d");
        anim.setAttribute("values", w.frames);
        anim.setAttribute("dur", w.duration + "s");
        anim.setAttribute("repeatCount", "indefinite");
        path.appendChild(anim);
        svg.appendChild(path);
      });

      var text = document.createElementNS(NS, "text");
      text.setAttribute("class", "hero-path-text");
      var textPath = document.createElementNS(NS, "textPath");
      textPath.setAttribute("href", "#outputTextPath");
      textPath.textContent = REPEATED_TEXT;
      var textAnim = document.createElementNS(NS, "animate");
      textAnim.setAttribute("attributeName", "startOffset");
      textAnim.setAttribute("from", "-1300");
      textAnim.setAttribute("to", "0");
      textAnim.setAttribute("dur", "15.5s");
      textAnim.setAttribute("calcMode", "linear");
      textAnim.setAttribute("repeatCount", "indefinite");
      textPath.appendChild(textAnim);
      text.appendChild(textPath);
      svg.appendChild(text);

      SPARKS.forEach(function (s) {
        var c = document.createElementNS(NS, "circle");
        c.setAttribute("cx", String(iconX));
        c.setAttribute("cy", String(iconY));
        c.setAttribute("r", "3");
        c.setAttribute("class", "hero-spark");

        function addAnim(attr: string, vals: string, dur: number, begin: number) {
          var a = document.createElementNS(NS, "animate");
          a.setAttribute("attributeName", attr);
          a.setAttribute("values", vals);
          a.setAttribute("dur", dur + "s");
          a.setAttribute("begin", begin + "s");
          a.setAttribute("repeatCount", "indefinite");
          c.appendChild(a);
        }

        addAnim("cx", iconX + ";" + (iconX + s.tx), s.dur, s.delay);
        addAnim("cy", iconY + ";" + (iconY + s.ty), s.dur, s.delay);
        addAnim("opacity", "0.6;0", s.dur, s.delay);
        addAnim("r", "3;1", s.dur, s.delay);
        svg.appendChild(c);
      });

      var glow = document.createElementNS(NS, "circle");
      glow.setAttribute("cx", String(iconX));
      glow.setAttribute("cy", String(iconY));
      glow.setAttribute("r", "38");
      glow.setAttribute("class", "hero-icon-glow");
      svg.appendChild(glow);

      var circle = document.createElementNS(NS, "circle");
      circle.setAttribute("cx", String(iconX));
      circle.setAttribute("cy", String(iconY));
      circle.setAttribute("r", "30");
      circle.setAttribute("class", "hero-icon-circle");
      svg.appendChild(circle);

      var img = document.createElementNS(NS, "image");
      img.setAttribute("href", "/app-logo.svg");
      img.setAttribute("x", String(iconX - 20));
      img.setAttribute("y", String(iconY - 20));
      img.setAttribute("width", "40");
      img.setAttribute("height", "40");
      img.setAttribute("class", "hero-icon-logo");
      svg.appendChild(img);

      return svg;
    }

    function init() {
      var containers = document.querySelectorAll(".hero-graphic");
      containers.forEach(function (el) {
        if (el.childElementCount > 0) return;
        el.appendChild(buildGraphic());
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
