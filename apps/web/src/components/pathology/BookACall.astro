---
interface Props {
	class?: string;
	label?: string;
}

const { class: className = '', label = 'Book a call' } = Astro.props;
const href = 'https://calendar.app.google/j64iosi7sjJretxd9';
---

<a
	href={href}
	target="_blank"
	rel="noopener noreferrer"
	class:list={['book-a-call', className]}
	data-track="PathologyBookACall"
>
	<span class="book-a-call-icon" aria-hidden="true"></span>
	<span>{label}</span>
</a>

<style>
	.book-a-call {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	.book-a-call-icon {
		display: inline-block;
		width: 18px;
		height: 18px;
		background-color: currentColor;
		mask: url('/calendar.svg') center/contain no-repeat;
		-webkit-mask: url('/calendar.svg') center/contain no-repeat;
		flex-shrink: 0;
	}
</style>
