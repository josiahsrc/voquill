{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "i18n:extract": "formatjs extract \"src/**/*.{ts,tsx}\" --ignore \"src/**/*.d.ts\" --out-file src/i18n/locales/en.json --format ./scripts/formatjs-formatter.mjs --id-interpolation-pattern \"[sha1:contenthash:base64:6]\"",
    "i18n:sync": "node ./scripts/i18n-sync.mjs"
  },
  "dependencies": {
    "marked": "^16.4.0",
    "mixpanel-browser": "^2.73.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-intl": "^7.1.14"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.7.4",
    "@repo/eslint-config": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@svgr/webpack": "^8.1.0",
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "babel-plugin-formatjs": "^10.5.41",
    "eslint": "^9.34.0",
    "typescript": "5.9.2"
  }
}
