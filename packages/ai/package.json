{
  "name": "@voquill/ai",
  "version": "0.1.0",
  "description": "Mastra AI agent sidecar for Voquill.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx ./src/server.ts",
    "dev:server": "node --import tsx ./src/server.ts",
    "cli": "node --import tsx ./scripts/cli.ts",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/openai": "latest",
    "@mastra/core": "latest",
    "@repo/types": "workspace:*",
    "ai": "^6.0.116"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "mastra": "latest",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
